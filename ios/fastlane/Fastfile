require 'base64'

default_platform(:ios)

APP_IDENTIFIER = "com.hobbylabo.kusuridoki"

platform :ios do
  before_all do
    @api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_ISSUER_ID"],
      key_content: ENV["APP_STORE_CONNECT_KEY_P8"],
      is_key_content_base64: true,
    )
  end

  desc "Sync App Store certificates and provisioning profiles via Match"
  lane :sync_certs do
    match(
      type: "appstore",
      readonly: is_ci,
      api_key: @api_key,
    )
  end

  desc "Build the iOS app with proper code signing"
  lane :build do
    sh("cd ../.. && flutter pub get")
    sync_certs

    # Auto-increment build number based on latest TestFlight build
    current_build = latest_testflight_build_number(
      api_key: @api_key,
      app_identifier: APP_IDENTIFIER,
    )
    increment_build_number(
      build_number: current_build + 1,
      xcodeproj: "Runner.xcodeproj",
    )

    # Strip IntegrationTestPlugin from release build.
    # GeneratedPluginRegistrant.m has #ifdef DEBUG guards when committed,
    # but flutter pub get regenerates the file without them.
    # This sed is a safety net for that case.
    sh("sed -i '' '/#if __has_include.*integration_test/,/#endif/d; /IntegrationTestPlugin registerWithRegistrar/d' ../Runner/GeneratedPluginRegistrant.m")

    dart_defines = Base64.strict_encode64("SENTRY_DSN=#{ENV['SENTRY_DSN'] || ''}")
    build_app(
      workspace: "Runner.xcworkspace",
      scheme: "Runner",
      configuration: "Release",
      export_method: "app-store",
      export_options: {
        provisioningProfiles: {
          APP_IDENTIFIER => "match AppStore #{APP_IDENTIFIER}",
        },
      },
      clean: true,
      output_name: "Kusuridoki.ipa",
      xcargs: "DART_DEFINES=\"#{dart_defines}\"",
    )

    # Upload dSYMs and source maps to Sentry
    sh("cd ../.. && dart run sentry_dart_plugin")

    # Restore GeneratedPluginRegistrant.m (with #ifdef DEBUG guards)
    sh("git checkout ../Runner/GeneratedPluginRegistrant.m 2>/dev/null || true")
  end

  desc "Build and upload to TestFlight"
  lane :beta do
    build
    upload_to_testflight(
      api_key: @api_key,
      skip_waiting_for_build_processing: true,
    )
  end

  desc "Capture App Store screenshots — all 8 screens (6.7-inch, Japanese)"
  lane :screenshots do
    device = "iPhone 15 Pro Max" # 6.7-inch App Store category (available locally)

    # Boot simulator if not already running
    sh("xcrun simctl boot '#{device}' 2>/dev/null || true")

    # Run flutter drive from project root (captures all 8 screens)
    sh(
      "cd ../.. && flutter drive " \
      "--driver=test_driver/screenshot_driver.dart " \
      "--target=integration_test/screenshots/all_screenshots_test.dart " \
      "-d '#{device}'"
    )

    puts "Screenshots saved to assets/marketing/screenshots/ (by screenshot_driver)"
  end

  desc "Build and upload to App Store (manual review submission)"
  lane :release do
    build
    upload_to_app_store(
      api_key: @api_key,
      submit_for_review: false,
      force: true,
    )
  end

  desc "Upload screenshots only to App Store Connect (skips binary and metadata)"
  lane :upload_screenshots do
    upload_to_app_store(
      api_key: @api_key,
      skip_binary_upload: true,
      skip_metadata: true,
      overwrite_screenshots: true,
      submit_for_review: false,
      force: true,
      run_precheck_before_submit: false,
    )
  end

  desc "Generate marketing store screenshots from raw captures (Python + Pillow)"
  lane :generate_store_screenshots do
    sh("cd ../.. && python3 scripts/generate_store_screenshots.py")
    sh("mkdir -p ./screenshots/ja")
    # Remove any non-store files to avoid mixing raw and marketing screenshots
    sh("find ./screenshots/ja -name '*.png' ! -name '*_store.png' -delete")
    sh("cp ../../assets/marketing/store/*.png ./screenshots/ja/")
    puts "Marketing screenshots copied to ios/fastlane/screenshots/ja/"
  end

  desc "Full pipeline: capture raw screenshots → generate marketing images → copy to fastlane"
  lane :store_screenshots do
    screenshots
    generate_store_screenshots
  end

  desc "Build and upload to App Store without Match (uses local certificate + downloads profile)"
  lane :release_local do
    # Download App Store provisioning profile via API key
    profile_path = get_provisioning_profile(
      api_key: @api_key,
      app_identifier: APP_IDENTIFIER,
      output_path: "./fastlane/profiles",
    )
    profile_uuid = ENV["sigh_#{APP_IDENTIFIER}_appstore_profile-uuid"]

    # Auto-increment build number based on latest TestFlight build
    current_build = latest_testflight_build_number(
      api_key: @api_key,
      app_identifier: APP_IDENTIFIER,
    )
    increment_build_number(
      build_number: current_build + 1,
      xcodeproj: "Runner.xcodeproj",
    )

    # Strip IntegrationTestPlugin from release build.
    # GeneratedPluginRegistrant.m has #ifdef DEBUG guards when committed,
    # but flutter pub get regenerates the file without them.
    # This sed removes both the import block AND the registration call.
    sh("sed -i '' '/#if __has_include.*integration_test/,/#endif/d; /IntegrationTestPlugin registerWithRegistrar/d' ../Runner/GeneratedPluginRegistrant.m")

    # Build using downloaded profile
    dart_defines = Base64.strict_encode64("SENTRY_DSN=#{ENV['SENTRY_DSN'] || ''}")
    build_app(
      workspace: "Runner.xcworkspace",
      scheme: "Runner",
      configuration: "Release",
      export_method: "app-store",
      export_options: {
        provisioningProfiles: {
          APP_IDENTIFIER => profile_uuid,
        },
        signingStyle: "manual",
        signingCertificate: "Apple Distribution",
      },
      clean: true,
      output_name: "Kusuridoki.ipa",
      xcargs: "DART_DEFINES=\"#{dart_defines}\"",
    )

    # Restore GeneratedPluginRegistrant.m for development use
    sh("git checkout ../Runner/GeneratedPluginRegistrant.m 2>/dev/null || true")

    upload_to_app_store(
      api_key: @api_key,
      submit_for_review: false,
      skip_screenshots: true,
      skip_metadata: true,
      force: true,
      run_precheck_before_submit: false,
    )
  end
end
