# Uncomment this line to define a global platform for your project
platform :ios, '15.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '15.0'
    end

    # Exclude integration_test from Release/Profile builds to prevent
    # "Test finished." overlay in production (Guideline 2.1/2.2).
    if target.name == 'integration_test'
      target.build_configurations.each do |config|
        unless config.name == 'Debug'
          config.build_settings['EXCLUDED_SOURCE_FILE_NAMES'] = '**'
        end
      end
    end
  end

  # Re-apply #ifdef DEBUG guards around integration_test in GeneratedPluginRegistrant.m.
  # flutter pub get regenerates this file without guards, so we patch it here
  # (post_install runs after pod install, which Flutter triggers on dependency changes).
  registrant = File.join(File.dirname(File.realpath(__FILE__)), 'Runner/GeneratedPluginRegistrant.m')
  if File.exist?(registrant)
    content = File.read(registrant)
    unless content.include?("#ifdef DEBUG\n#if __has_include(<integration_test/")
      content.sub!(
        "#if __has_include(<integration_test/IntegrationTestPlugin.h>)\n#import <integration_test/IntegrationTestPlugin.h>\n#else\n@import integration_test;\n#endif",
        "#ifdef DEBUG\n#if __has_include(<integration_test/IntegrationTestPlugin.h>)\n#import <integration_test/IntegrationTestPlugin.h>\n#else\n@import integration_test;\n#endif\n#endif"
      )
    end
    unless content.include?("#ifdef DEBUG\n  [IntegrationTestPlugin")
      content.sub!(
        "  [IntegrationTestPlugin registerWithRegistrar:[registry registrarForPlugin:@\"IntegrationTestPlugin\"]];",
        "#ifdef DEBUG\n  [IntegrationTestPlugin registerWithRegistrar:[registry registrarForPlugin:@\"IntegrationTestPlugin\"]];\n#endif"
      )
    end
    File.write(registrant, content)
  end

  # Remove integration_test from Release/Profile linker flags in CocoaPods-generated xcconfigs.
  # EXCLUDED_SOURCE_FILE_NAMES prevents compilation, but the linker still fails unless we also
  # remove the -framework flag from the xcconfig files.
  %w[release profile].each do |config_name|
    xcconfig = File.join(
      installer.sandbox.root,
      "Target Support Files/Pods-Runner/Pods-Runner.#{config_name}.xcconfig"
    )
    next unless File.exist?(xcconfig)
    content = File.read(xcconfig)
    modified = content.gsub(/-framework\s+"?integration_test"?\s?/, '')
    File.write(xcconfig, modified) if modified != content
  end

  # Prevent integration_test.framework from being embedded in Release/Profile builds.
  # EXCLUDED_SOURCE_FILE_NAMES blocks compilation but the embed script still copies the
  # empty framework folder, causing MIInstallerErrorDomain error 71 on device install.
  frameworks_script = File.join(
    installer.sandbox.root,
    "Target Support Files/Pods-Runner/Pods-Runner-frameworks.sh"
  )
  if File.exist?(frameworks_script)
    content = File.read(frameworks_script)
    content.gsub!(
      /([ \t]*)(install_framework "\$\{BUILT_PRODUCTS_DIR\}\/integration_test\/integration_test\.framework")/,
      '\1if [[ "${CONFIGURATION}" == "Debug" ]]; then \2; fi'
    )
    File.write(frameworks_script, content)
    FileUtils.chmod('+x', frameworks_script)
  end
end
